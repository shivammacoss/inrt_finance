# Default dev ports: API 5001, frontend 3033 (avoids common clashes on 5000/3030)
PORT=5001
NODE_ENV=development

# Atlas (cloud): mongodb+srv://user:pass@cluster.mongodb.net/inrt?retryWrites=true&w=majority
# Local MongoDB (no Docker): mongodb://127.0.0.1:27017/inrt
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/inrt?retryWrites=true&w=majority
JWT_SECRET=change-me-to-long-random-string-min-32-chars
# Short-lived access JWT (cookies). Refresh uses opaque tokens in DB.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Legacy alias (optional)
JWT_EXPIRES_IN=7d

# CORS + cookies: comma-separated origins (user app + admin portal). Trailing slashes optional.
# Production example: https://inrt.finance,https://admin.inrt.finance
FRONTEND_URL=http://localhost:3033

# Optional fintech limits (token units, decimal strings)
USER_DAILY_WITHDRAW_LIMIT=
GLOBAL_WITHDRAW_DAILY_FRACTION=0.2

# Optional reserve fields (set via DB PlatformSettings or seed); see admin stats
# RESERVE_TOKEN_CAP / RESERVE_INR can be stored in Mongo PlatformSettings

# BNB Smart Chain
RPC_URL=https://bsc-dataseed.binance.org/
CONTRACT_ADDRESS=0xYourINRTTokenAddress
PRIVATE_KEY=0x...hot-wallet-signer-never-commit
# Optional: force token decimals (avoids decimals() RPC). Typical INRT: 6 or 18
TOKEN_DECIMALS=6

# Receiving address for deposits (defaults to signer address if omitted)
DEPOSIT_ADDRESS=

# Optional: comma-separated admin emails promoted on register()
ADMIN_EMAILS=admin@inrt.com

# Bootstrap first admin (npm run seed:admin — creates or resets password)
ADMIN_BOOTSTRAP_EMAIL=admin@inrt.com
ADMIN_BOOTSTRAP_PASSWORD=InrtAdmin@2026

# Demo users: npm run seed:demo  → see DEMO_ACCOUNTS.txt

# Shown on GET /wallet/deposit-info (dashboard payment instructions)
PAYMENT_UPI_ID=
PAYMENT_UPI_NAME=INRT
PAYMENT_BANK_HOLDER=
PAYMENT_BANK_ACCOUNT=
PAYMENT_BANK_IFSC=
PAYMENT_BANK_NAME=
PAYMENT_CARD_INSTRUCTIONS=
PAYMENT_OTHER_INSTRUCTIONS=

# Razorpay (INR → INRT). Node provides crypto; only install the razorpay package.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: HMAC secret from Razorpay Dashboard → Webhooks (POST /payment/webhook)
RAZORPAY_WEBHOOK_SECRET=
# safe = verified payment → pending Request → admin approves mint | auto = mint + credit after verify
RAZORPAY_DEPOSIT_MODE=safe
RAZORPAY_MIN_INR=1
RAZORPAY_MAX_INR=500000
# Decimal string: INRT credited per 1 INR (e.g. 1 means 100 INR → 100 INRT)
INRT_PER_INR_RATE=1
