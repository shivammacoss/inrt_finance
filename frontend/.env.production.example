# Build-time public API origin — must match where the browser loads the API (same-site preferred).
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# Must match the admin hostname so middleware can route admin.yourdomain → /admin/login
NEXT_PUBLIC_ADMIN_HOST=admin.yourdomain.com
# Public user app URL (link from admin login back to users)
NEXT_PUBLIC_USER_APP_ORIGIN=https://yourdomain.com
